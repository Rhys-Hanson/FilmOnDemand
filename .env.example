# FilmOnDemand backend environment variables
# Copy this file to .env and replace every placeholder with your real keys.
# Never commit your real .env file or API secrets.

# TasteDive API
# Get a key: https://tastedive.com/account/api_access
TASTEDIVE_API_KEY=your_tastedive_api_key_here

# TMDb API
# Create an account, then request a key here: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Trakt API
# 1. Create a free account at https://trakt.tv
# 2. Go to https://trakt.tv/oauth/applications
# 3. Click New Application
# 4. Use any app name and set Redirect URI to: urn:ietf:wg:oauth:2.0:oob
# 5. Save and copy the generated Client ID
TRAKT_API_KEY=your_trakt_client_id_here

# Watchmode API
# Request a key here: https://api.watchmode.com/requestApiKey/
WATCHMODE_API_KEY=your_watchmode_api_key_here

# OMDb API
# Free tier available. Request a key here: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Gemini API
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Local development toggle
# true = use mock movie data instead of live API calls
# false = use live APIs
USE_MOCK_DATA=false
