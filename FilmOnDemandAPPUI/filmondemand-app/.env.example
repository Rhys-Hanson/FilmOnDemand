# Public URL where the frontend is hosted.
VITE_APP_URL="http://localhost:3000"

# Base HTTP URL for the backend API, including /api.
VITE_API_BASE_URL="http://localhost:8000/api"

# Optional explicit WebSocket base URL for the backend.
# If omitted, the app derives it from VITE_API_BASE_URL.
VITE_WS_BASE_URL="ws://localhost:8000"
